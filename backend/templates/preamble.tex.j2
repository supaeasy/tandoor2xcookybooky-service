% xcookybooky sets \fancyhead[R]{\rightmark} (repeating the recipe name in
% the top-right corner) and a header rule that the recipe picture can overlap
% (it's nudged up internally via \vspace{-0.6cm}). Define a pagestyle with no
% header/rule at all (keeping only the page number in the footer) and apply
% it per recipe - see recipe_fragment.tex.j2.
\fancypagestyle{xcbrecipe}{%
    \fancyhf{}
    \fancyfoot[R]{\thepage}
    \renewcommand{\headrulewidth}{0pt}
}
\DeclareRobustCommand{\textcelcius}{\ensuremath{^{\circ}\mathrm{C}}\hspace{0.3em}}
