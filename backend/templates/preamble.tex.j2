\fancyhead[LE,RO]{}
\DeclareRobustCommand{\textcelcius}{\ensuremath{^{\circ}\mathrm{C}}\hspace{0.3em}}
\setcounter{secnumdepth}{1}
\renewcommand*{\recipesection}[2][]{\subsection[#1]{#2}}
\usepackage{hyperref}
\hypersetup{%
pdfauthor={<< pdf_author >>},
pdftitle={<< pdf_title >>},
pdfsubject={Rezept},
pdfkeywords={Rezept Kochbuch xcookybooky LaTeX, Recipe},
pdfstartview={FitV},
pdfview={FitH},
pdfpagemode={UseNone},
bookmarksopen={true},
colorlinks={true},
linkcolor={black},
urlcolor={blue},
citecolor={black},
filecolor={black}
}
\hbadness=10000
% Extra clearance vs. the original single-recipe template's values, so the
% recipe picture (which xcookybooky nudges up by \vspace{-0.6cm} internally)
% no longer overlaps the header rule.
\setlength{\headsep}{1cm}
\setlength{\footskip}{14pt}
\setlength{\topmargin}{-0.4cm} \setlength{\textheight}{24.4cm}
